#!/bin/sh
#
# git pre-push hook — triggers the Jenkins iOS deploy pipeline when you push.
# Installed into .git/hooks/pre-push by ci/install-git-hook.sh
#
# The build job checks out the repo from GitHub, so we wait a few seconds for
# the push to land on GitHub before asking Jenkins to build. The /buildByToken
# endpoint (Build Token Root plugin) is exempt from CSRF/login.
#
JOB_URL="http://localhost:8090/buildByToken/build?job=travelandfun-ios&token=travelandfun-deploy"

# Fire-and-forget in the background so `git push` returns immediately.
( sleep 12; curl -fsS -X POST "$JOB_URL" >/dev/null 2>&1 ) &

echo "[jenkins] iOS deploy will be triggered ~12s after this push completes"
exit 0
