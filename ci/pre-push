#!/bin/sh
#
# git pre-push hook — triggers the Jenkins pipelines when you push.
# Installed into .git/hooks/pre-push by ci/install-git-hook.sh
#
# Waits a few seconds for the push to reach GitHub, then triggers:
#   1) travelandfun-ios        -> build & install on the USB iPhone
#   2) travelandfun-testflight -> build & upload to TestFlight
# /buildByToken is exempt from CSRF/login.
#
BASE="http://localhost:8090/buildByToken/build"
DEPLOY_URL="$BASE?job=travelandfun-ios&token=travelandfun-deploy"
TESTFLIGHT_URL="$BASE?job=travelandfun-testflight&token=travelandfun-testflight"

(
  sleep 12
  curl -fsS -X POST "$DEPLOY_URL"     >/dev/null 2>&1
  curl -fsS -X POST "$TESTFLIGHT_URL" >/dev/null 2>&1
) &

echo "[jenkins] iOS deploy + TestFlight will be triggered ~12s after this push completes"
exit 0
